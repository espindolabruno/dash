# Configurações do Dashboard
PORT=3000
DASH_USER=admin
DASH_PASSWORD=suasenhaforte123   # Senha de acesso ao painel VPS

# Credenciais Google OAuth2 (Google Cloud Console)
GOOGLE_CLIENT_ID=seu_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_gocspx
GOOGLE_REDIRECT_URI=https://aprovacoes.connectagromkt.com.br/api/google/callback

# Token de Acesso Contínuo (Gerado na primeira autenticação e mantido aqui)
GOOGLE_REFRESH_TOKEN=seu_refresh_token_aqui

# ID da pasta raiz "Clientes" no Google Drive
GOOGLE_DRIVE_FOLDER_ID=id_da_pasta_raiz_clientes

# Credenciais Meta Ads API v25.0
META_ACCESS_TOKEN=EAAW_seu_token_permanente_de_usuario_do_sistema
META_AD_ACCOUNT_ID=act_sua_conta_de_anuncios

# Meta App OAuth Credentials (necessário se for utilizar login por cliente)
META_APP_ID=seu_meta_app_id
META_APP_SECRET=seu_meta_app_secret
META_REDIRECT_URI=https://aprovacoes.connectagromkt.com.br/api/meta/callback

# Chave de API da Anthropic (Claude) para recursos de IA (Insights/Diagnósticos)
